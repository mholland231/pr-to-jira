{
  "manifest_version": 3,
  "name": "PR to JIRA",
  "version": "1.0.0",
  "description": "Create JIRA tickets from GitHub Pull Requests with one click.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://*.atlassian.net/*",
    "https://api.github.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*/pull/*"],
      "js": ["lib/pr-parser.js", "content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
